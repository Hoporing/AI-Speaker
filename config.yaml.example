audio:
  input_device: null       # null = 시스템 기본 마이크
  output_device: null      # null = 시스템 기본 스피커
  sample_rate: 16000
  chunk_size: 512
  min_duration: 0.5
  min_avg_volume: 0.01
  wait_for_speech_timeout: 5.0

wake_word:
  model: "hey_jarvis"
  threshold: 0.5

vad:
  model_path: "./models/silero-vad"   # silero-vad repo 경로
  threshold: 0.5
  min_rms: 0.05
  min_silence_ms: 2000

stt:
  model_path: "./models/whisper-small"  # Whisper 모델 경로
  device: "cpu"                          # "cpu" or "cuda"
  language: "ko"

llm:
  model_path: "./models/Qwen2.5-3B-Instruct-Q4_K_M.gguf"  # GGUF 모델 경로
  n_ctx: 2048
  n_gpu_layers: 0       # GPU 사용 시 레이어 수 지정
  max_tokens: 512
  temperature: 0.7

tts:
  ckpt_path: "./models/melotts-korean/checkpoint.pth"
  config_path: "./models/melotts-korean/config.json"
  bert_path: "./models/bert-kor-base"
  language: "KR"
  speed: 1.0
